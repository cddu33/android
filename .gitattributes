# Set default behavior to automatically normalize line endings
* text=auto

# Explicitly declare text files you want to always be normalized and converted to native line endings on checkout.
*.kt text
*.kts text
*.xml text
*.gradle text
*.md text
*.json text
*.yml text
*.yaml text
*.toml text
*.properties text
*.pro text
*.txt text
*.bash text eol=lf
*.css text diff=css
*.sh text eol=lf

# Declare binary files to be preserved as-is
*.png binary
*.jpg binary
*.jar binary

# Custom merge driver for Gradle lock files
gradle.lockfile merge=union

# Ensure shell scripts have UNIX line endings
*.sh text eol=lf

# Ensure Windows batch files have CRLF line endings
*.bat text eol=crlf

# Handle Android Studio specific files
*.iml text
*.idea/** text

# Protect build and version files on this branch — always keep our version when merging
# The 'keepours' driver must be configured locally: git config merge.keepours.driver true
gradle/libs.versions.toml merge=keepours
gradle/wrapper/gradle-wrapper.properties merge=keepours
build.gradle.kts merge=keepours
settings.gradle.kts merge=keepours
app/build.gradle.kts merge=keepours
automotive/build.gradle.kts merge=keepours
wear/build.gradle.kts merge=keepours
common/build.gradle.kts merge=keepours
